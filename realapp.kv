                            height: dp(22)

                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(60)
                            spacing: dp(14)
                            padding: [dp(4), 0]

                            MDBoxLayout:
                                size_hint: None, None
