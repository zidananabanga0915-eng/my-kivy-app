                                        text_color: 0.55, 0.55, 0.55, 1
            Screen:
                name: "Settings Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    md_bg_color: app.bg_color

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        md_bg_color: app.primary_color
                        padding: [dp(5), 0]
                        spacing: dp(5)

                        MDIconButton:
                            icon: "arrow-left"
                            theme_icon_color: "Custom"
                            icon_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}
                            on_release: app.close_settings()

                        MDLabel:
                            text: "Settings"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            valign: "center"

                    ScrollView:
                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            padding: [dp(15), dp(15)]
                            spacing: dp(10)

                            MDLabel:
                                text: "General"
                                bold: True
                                font_size: dp(16)
                                theme_text_color: "Custom"
                                text_color: app.primary_color
                                size_hint_y: None
                                height: dp(30)

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(72)
                                md_bg_color: app.surface_color
                                radius: [12]
                                padding: [dp(16), 0]
                                spacing: dp(14)

                                MDBoxLayout:
                                    size_hint: None, None
                                    size: dp(38), dp(38)
                                    radius: [19]
                                    md_bg_color: app.primary_color
                                    pos_hint: {"center_y": 0.5}

                                    MDIcon:
                                        icon: "circle-half-full"
                                        theme_text_color: "Custom"
                                        text_color: 1, 1, 1, 1
                                        halign: "center"
                                        valign: "center"

                                MDBoxLayout:
                                    orientation: "vertical"
                                    pos_hint: {"center_y": 0.5}
                                    spacing: dp(2)

                                    MDLabel:
                                        text: "Dark Mode"
                                        bold: True
                                        font_size: dp(15)
                                        theme_text_color: "Custom"
                                        text_color: app.text_primary
                                        size_hint_y: None
                                        height: dp(22)

                                    MDLabel:
                                        text: "Enable"
