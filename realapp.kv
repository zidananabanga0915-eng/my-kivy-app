                                        size_hint_y: None
                                        height: dp(22)

                                    MDLabel:
                                        text: "Enable"
                                        font_size: dp(12)
                                        theme_text_color: "Custom"
                                        text_color: app.text_secondary
                                        size_hint_y: None
                                        height: dp(18)

                                Widget:
                                    size_hint_x: 1

                                MDSwitch:
                                    active: app.completion_tone
                                    pos_hint: {"center_y": 0.5}
                                    on_active: app.toggle_completion_tone(self.active)

            Screen:
                name: "FAQ Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    md_bg_color: app.bg_color

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        md_bg_color: app.primary_color
                        padding: [dp(5), 0]
                        spacing: dp(5)

                        MDIconButton:
                            icon: "arrow-left"
                            theme_icon_color: "Custom"
                            icon_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}
                            on_release: app.close_faq()

                        MDLabel:
                            text: "FAQ"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            valign: "center"

                    ScrollView:
                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            padding: [dp(12), dp(12)]
                            spacing: dp(10)

                            FaqItem:
                                question: "How to create a new task?"
                                answer: "1. Click on the plus button next to the navigation bar.\n2. Enter your title.\n3. Optional: choose priority and date due."

                            FaqItem:
                                question: "How to search for apps?"
                                answer: "1. Click on the magnify icon at the top and enter your task."

                            FaqItem:
                                question: "How to delete a task?"
                                answer: "1. Click on the trash icon in the task created."

                            FaqItem:
                                question: "How to categorize tasks?"
                                answer: "1. Select the section you want your task to be under.\n2. Personal, Work, School and Other — to create task under them."

                            FaqItem:
                                question: "How to mark a task as completed?"
                                answer: "1. Click in the checkbox in the created task."

                            FaqItem:
                                question: "Can a task be pinned?"
                                answer: "1. Long press the created task and select Pin."

                            FaqItem:
                                question: "How to view tasks by category?"
                                answer: "1. Check the chart in the statistics."

                            FaqItem:
                                question: "How to mark a task as favorite?"
                                answer: "1. Long press on the created task and select favorite."

                            FaqItem:
                                question: "How to change app theme?"
                                answer: "1. Click on the 3 lines at the top.\n2. Click on Theme and select preferred color and click Apply."

                            FaqItem:
                                question: "How to enable dark mode?"
                                answer: "1. Click on the 3 lines at the top.\n2. Click on Settings and switch on dark mode."

                            FaqItem:
                                question: "How long do tasks stay in trash?"
                                answer: "1. It takes 10 days before deleted tasks in trash disappear."

        # Bottom navbar
        MDBoxLayout:
            size_hint: 0.85, None
            height: 170
            padding: [15, 15]
            pos_hint: {"center_x": 0.38, "center_y": 0.02}
            size_hint_x: 0.7

            MDBoxLayout:
                orientation: "horizontal"
                spacing: 8
                padding: [10, 15]
                md_bg_color: 0, 0, 0, 1
                radius: [70]

                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 0.3
                    Line:
                        width: 8
                        rounded_rectangle: (self.x + 1.5, self.y + 1.5, self.width - 3, self.height - 3, 60)

                Navitem:
                    icon: "check-circle"
                    text: "Task"
                    screen: "Task Screen"
                    size_hint_x: 1

                Navitem:
                    icon: "calendar"
                    text: "Calendar"
                    screen: "Calendar Screen"
                    size_hint_x: 1

                Navitem:
                    icon: "view-dashboard"
                    text: "Record"
                    screen: "Statistics"
                    size_hint_x: 1

    # ── FAB Button (fixed: plain Button with full canvas control) ──
    Button:
        size_hint: None, None
        size: dp(80), dp(80)
        pos_hint: {"center_x": 0.88, "center_y": 0.06}
        background_color: 0, 0, 0, 0
        background_normal: ""
        background_down: ""
        on_release: app.add_task()

        canvas.before:
        # 1. Gray outer ring
            Color:               
                rgba: 0.6, 0.6, 0.6, 1
            Ellipse:
                pos: self.x - dp(6), self.y - dp(6)
                size: self.width + dp(12), self.height + dp(12)
        # 2. Dark gap
            Color:
                rgba: 0.15, 0.15, 0.15, 1
            Ellipse:
                pos: self.x - dp(3), self.y - dp(3)
                size: self.width + dp(6), self.height + dp(6)
        # 3. Blue circle
            Color:
                rgba: app.primary_color
            Ellipse:
                pos: self.pos
                size: self.size

        canvas:
        # Draw "+" icon centered
            Color:
                rgba: 1, 1, 1, 1
        # Horizontal bar
            Rectangle:
                pos: self.center_x - dp(12), self.center_y - dp(2)
                size: dp(24), dp(4)
        # Vertical bar
            Rectangle:
                pos: self.center_x - dp(2), self.center_y - dp(12)
                size: dp(4), dp(24)

    # ── Bottom sheet ──
    MDBoxLayout:
        id: task_bottom_sheet
        orientation: "vertical"
        size_hint: 1, None
        height: dp(220)
        md_bg_color: 1, 1, 1, 1
        radius: [20, 20, 0, 0]
        padding: [dp(20), dp(10)]
        spacing: dp(10)
        pos_hint: {"center_x": 0.5, "y": -1}

        MDBoxLayout:
            size_hint: None, None
            size: dp(40), dp(4)
            md_bg_color: 0.7, 0.7, 0.7, 1
            radius: [2]
            pos_hint: {"center_x": 0.5}

        MDBoxLayout:
            size_hint: 1, None
            height: dp(80)
            md_bg_color: 0.9, 0.9, 0.9, 1
            radius: [25]
            orientation: "vertical"
            padding: [0, 5]

            TextInput:
                id: task_input
                hint_text: "Enter a task..."
                size_hint_y: None
                height: dp(50)
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0, 0, 0, 0
                padding: [15, 12, 15, 5]
                foreground_color: 0, 0, 0, 1
                hint_text_color: 0.6, 0.6, 0.6, 1
                font_size: dp(18)
                cursor_color: 0, 0, 0, 1

            MDLabel:
                id: date_label
                text: app.selected_date
                size_hint_y: None
                height: dp(20)
                font_size: dp(11)
                theme_text_color: "Custom"
                text_color: 1, 0.2, 0.2, 1
                padding: [15, 0]

        MDBoxLayout:
            orientation: "horizontal"
            size_hint: 1, None
            height: dp(40)
            spacing: dp(8)

            MDBoxLayout:
                size_hint: None, None
                size: dp(110), dp(38)
                radius: [19]
                md_bg_color: 0.9, 0.9, 0.9, 1
                spacing: dp(5)
                padding: [8, 0]

                MDIconButton:
                    icon: "calendar"
                    size_hint: None, None
                    size: dp(30), dp(38)
                    theme_icon_color: "Custom"
                    icon_color: 0.3, 0.3, 0.3, 1
                    on_release: app.show_date_picker()

                MDLabel:
                    text: "Calendar"
                    font_size: dp(12)
                    theme_text_color: "Custom"
                    text_color: 0.3, 0.3, 0.3, 1
                    valign: "center"

            MDBoxLayout:
                size_hint: None, None
                size: dp(110), dp(38)
                radius: [19]
                md_bg_color: 0.9, 0.9, 0.9, 1
                spacing: dp(5)
                padding: [8, 0]

                MDIconButton:
                    id: flag_btn
                    icon: "flag-outline"
                    size_hint: None, None
                    size: dp(30), dp(38)
                    theme_icon_color: "Custom"
                    icon_color: 0.5, 0.5, 0.5, 1
                    on_release: app.show_priority_menu()

                MDLabel:
                    text: "Priority"
                    font_size: dp(12)
                    theme_text_color: "Custom"
                    text_color: 0.3, 0.3, 0.3, 1
                    valign: "center"

            MDBoxLayout:
                size_hint: None, None
                size: dp(110), dp(38)
                radius: [19]
                md_bg_color: 0.9, 0.9, 0.9, 1
                spacing: dp(5)
                padding: [8, 0]

                MDIconButton:
                    id: repeat_btn
                    icon: "repeat"
                    size_hint: None, None
                    size: dp(30), dp(38)
                    theme_icon_color: "Custom"
                    icon_color: 0.3, 0.3, 0.3, 1
                    on_release: app.show_repeat_menu()

                MDLabel:
                    text: "Repeat"
                    font_size: dp(12)
                    theme_text_color: "Custom"
                    text_color: 0.3, 0.3, 0.3, 1
                    valign: "center"

            Widget:
                size_hint_x: 1

            MDIconButton:
                size_hint: None, None
                size: dp(36), dp(36)
                md_bg_color: app.primary_color
                radius: [18]
                icon: "send"
                theme_icon_color: "Custom"
                icon_color: 1, 1, 1, 1
                icon_size: "16sp"
                on_release: app.save_task()

    # ── Drawer overlay ──
    MDBoxLayout:
        id: drawer_overlay
        size_hint: 1, 1
        md_bg_color: 0, 0, 0, 0.4
        opacity: 0
        on_touch_down: app.close_drawer() if self.collide_point(*args[1].pos) else None

    # ── Navigation Drawer ──
    MDBoxLayout:
        id: nav_drawer
        orientation: "vertical"
        size_hint: None, 1
        width: dp(280)
        md_bg_color: app.primary_tint
        x: -dp(280)
        y: 0

        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(120)
            md_bg_color: app.primary_color
            padding: [dp(16), dp(20)]
            spacing: dp(14)

            MDBoxLayout:
                size_hint: None, None
                size: dp(60), dp(60)
                radius: [12]
                md_bg_color: 0.08, 0.3, 0.55, 1
                pos_hint: {"center_y": 0.5}

                MDIcon:
                    icon: "format-list-checks"
                    theme_text_color: "Custom"
                    text_color: 1, 0.85, 0.1, 1
                    font_size: dp(30)
                    halign: "center"
                    valign: "center"

            MDLabel:
                text: "TodoMaster"
                font_style: "H5"
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                valign: "center"

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: 1
            padding: [0, dp(8)]

            DrawerItem:
                icon: "check-circle-outline"
                label: "Task Detail"
                on_release: app.close_drawer()

            DrawerItem:
                icon: "chart-bar"
                label: "Task Overview"
                on_release: app.close_drawer(); app.change_screen("Statistics")

            DrawerItem:
                icon: "calendar-month-outline"
                label: "Calendar"
                on_release: app.close_drawer(); app.change_screen("Calendar Screen")

            DrawerItem:
                icon: "star-outline"
                label: "Favorites"
                on_release: app.open_favorites()

            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(52)
                padding: [dp(20), 0]
                spacing: dp(18)
                on_touch_down: self.collide_point(*args[1].pos) and app.toggle_category()

                MDIcon:
                    icon: "shape-outline"
                    theme_text_color: "Custom"
                    text_color: 0.1, 0.1, 0.1, 1
                    size_hint: None, None
                    size: dp(24), dp(24)
                    pos_hint: {"center_y": 0.5}

                MDLabel:
                    text: "Category"
                    font_size: dp(15)
                    theme_text_color: "Custom"
                    text_color: 0.1, 0.1, 0.1, 1
                    valign: "center"

                Widget:
                    size_hint_x: 1

                MDIcon:
                    icon: "chevron-up" if app.category_expanded else "chevron-down"
                    theme_text_color: "Custom"
                    text_color: 0.3, 0.3, 0.3, 1
                    size_hint: None, None
                    size: dp(20), dp(20)
                    pos_hint: {"center_y": 0.5}

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: dp(52) * 5 if app.category_expanded else 0
                opacity: 1 if app.category_expanded else 0

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(48), 0, dp(16), 0]
                    spacing: dp(18)
                    on_touch_down: self.collide_point(*args[1].pos) and app.close_drawer()

                    MDIcon:
                        icon: "format-list-bulleted"
                        theme_text_color: "Custom"
                        text_color: 0.2, 0.2, 0.2, 1
                        size_hint: None, None
                        size: dp(22), dp(22)
                        pos_hint: {"center_y": 0.5}

                    MDLabel:
                        text: "All"
                        font_size: dp(14)
                        theme_text_color: "Custom"
                        text_color: 0.15, 0.15, 0.15, 1
                        valign: "center"

                    Widget:
                        size_hint_x: 1

                    MDBoxLayout:
                        size_hint: None, None
                        size: dp(36), dp(26)
                        radius: [8]
                        md_bg_color: app.primary_color
                        pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: str(app.count_all)
                            halign: "center"
                            font_size: dp(12)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(48), 0, dp(16), 0]
                    spacing: dp(18)
                    on_touch_down: self.collide_point(*args[1].pos) and app.navigate_to_tab("Personal")

                    MDIcon:
                        icon: "format-list-bulleted"
                        theme_text_color: "Custom"
                        text_color: 0.2, 0.2, 0.2, 1
                        size_hint: None, None
                        size: dp(22), dp(22)
                        pos_hint: {"center_y": 0.5}

                    MDLabel:
                        text: "Personal"
                        font_size: dp(14)
                        theme_text_color: "Custom"
                        text_color: 0.15, 0.15, 0.15, 1
                        valign: "center"

                    Widget:
                        size_hint_x: 1

                    MDBoxLayout:
                        size_hint: None, None
                        size: dp(36), dp(26)
                        radius: [8]
                        md_bg_color: app.primary_color
                        pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: str(app.count_personal)
                            halign: "center"
                            font_size: dp(12)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(48), 0, dp(16), 0]
                    spacing: dp(18)
                    on_touch_down: self.collide_point(*args[1].pos) and app.navigate_to_tab("Work")

                    MDIcon:
                        icon: "format-list-bulleted"
                        theme_text_color: "Custom"
                        text_color: 0.2, 0.2, 0.2, 1
                        size_hint: None, None
                        size: dp(22), dp(22)
                        pos_hint: {"center_y": 0.5}

                    MDLabel:
                        text: "Work"
                        font_size: dp(14)
                        theme_text_color: "Custom"
                        text_color: 0.15, 0.15, 0.15, 1
                        valign: "center"

                    Widget:
                        size_hint_x: 1

                    MDBoxLayout:
                        size_hint: None, None
                        size: dp(36), dp(26)
                        radius: [8]
                        md_bg_color: app.primary_color
                        pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: str(app.count_work)
                            halign: "center"
                            font_size: dp(12)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(48), 0, dp(16), 0]
                    spacing: dp(18)
                    on_touch_down: self.collide_point(*args[1].pos) and app.navigate_to_tab("School")

                    MDIcon:
                        icon: "format-list-bulleted"
                        theme_text_color: "Custom"
                        text_color: 0.2, 0.2, 0.2, 1
                        size_hint: None, None
                        size: dp(22), dp(22)
                        pos_hint: {"center_y": 0.5}

                    MDLabel:
                        text: "School"
                        font_size: dp(14)
                        theme_text_color: "Custom"
                        text_color: 0.15, 0.15, 0.15, 1
                        valign: "center"

                    Widget:
                        size_hint_x: 1

                    MDBoxLayout:
                        size_hint: None, None
                        size: dp(36), dp(26)
                        radius: [8]
                        md_bg_color: app.primary_color
                        pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: str(app.count_school)
                            halign: "center"
                            font_size: dp(12)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(48), 0, dp(16), 0]
                    spacing: dp(18)
                    on_touch_down: self.collide_point(*args[1].pos) and app.navigate_to_tab("Other")

                    MDIcon:
                        icon: "format-list-bulleted"
                        theme_text_color: "Custom"
                        text_color: 0.2, 0.2, 0.2, 1
                        size_hint: None, None
                        size: dp(22), dp(22)
                        pos_hint: {"center_y": 0.5}

                    MDLabel:
                        text: "Other"
                        font_size: dp(14)
                        theme_text_color: "Custom"
                        text_color: 0.15, 0.15, 0.15, 1
                        valign: "center"

                    Widget:
                        size_hint_x: 1

                    MDBoxLayout:
                        size_hint: None, None
                        size: dp(36), dp(26)
                        radius: [8]
                        md_bg_color: app.primary_color
                        pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: str(app.count_other)
                            halign: "center"
                            font_size: dp(12)
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

            DrawerItem:
                icon: "palette-outline"
                label: "Theme"
                on_release: app.open_theme()

            DrawerItem:
                icon: "delete-outline"
                label: "Trash"
                on_release: app.open_trash()

            DrawerItem:
                icon: "help-circle-outline"
                label: "FAQ"
                on_release: app.open_faq()

            DrawerItem:
                icon: "cog-outline"
                label: "Settings"
                on_release: app.open_settings()

            Widget:
                size_hint_y: 1

      
               
                   
  