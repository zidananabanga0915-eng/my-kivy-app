                                        valign: "center"

                                MDBoxLayout:
                                    orientation: "vertical"
                                    pos_hint: {"center_y": 0.5}
                                    spacing: dp(2)

                                    MDLabel:
                                        text: "Swipe Gesture"
                                        bold: True
                                        font_size: dp(15)
                                        theme_text_color: "Custom"
                                        text_color: app.text_primary
                                        size_hint_y: None
                                        height: dp(22)

                                    MDLabel:
                                        text: "Enable"
                                        font_size: dp(12)
                                        theme_text_color: "Custom"
                                        text_color: app.text_secondary
                                        size_hint_y: None
                                        height: dp(18)

                                Widget:
                                    size_hint_x: 1

                                MDSwitch:
                                    active: app.swipe_gesture
                                    pos_hint: {"center_y": 0.5}
