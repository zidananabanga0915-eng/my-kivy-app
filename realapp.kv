            Screen:                                 
                name: "Statistics"
                MDBoxLayout:                    
                    orientation: "vertical"
                    md_bg_color: app.primary_tint

                    MDBoxLayout:                        
                        size_hint_y: None
                        height: dp(56)
                        padding: [15, 0]

                        MDLabel:                            
                            text: "Tasks Overview"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            valign: "center"

                    ScrollView:
                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            padding: [15, 10]
                            spacing: dp(15)

                            # ── Stat cards row ──────────────────────────
                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(100)
                                spacing: dp(15)

                                MDBoxLayout:
                                    orientation: "vertical"
                                    md_bg_color: 1, 1, 1, 1
                                    radius: [15]
                                    padding: dp(15)
                                    spacing: dp(5)

                                    MDLabel:
                                        id: stats_completed
                                        text: "0"
                                        halign: "center"
                                        bold: True
                                        font_size: dp(32)
                                        theme_text_color: "Custom"
                                        text_color: 0.1, 0.1, 0.1, 1

                                    MDLabel:
                                        text: "Completed Tasks"
                                        halign: "center"
                                        font_size: dp(12)
                                        theme_text_color: "Custom"
                                        text_color: 0.5, 0.5, 0.5, 1

                                MDBoxLayout:
                                    orientation: "vertical"
                                    md_bg_color: 1, 1, 1, 1
                                    radius: [15]
                                    padding: dp(15)
                                    spacing: dp(5)

                                    MDLabel:
                                        id: stats_pending
                                        text: "0"
                                        halign: "center"
                                        bold: True
                                        font_size: dp(32)
                                        theme_text_color: "Custom"
                                        text_color: 0.1, 0.1, 0.1, 1

                                    MDLabel:
                                        text: "Pending Tasks"
                                        halign: "center"
                                        font_size: dp(12)
                                        theme_text_color: "Custom"
                                        text_color: 0.5, 0.5, 0.5, 1

                            # ── Pie chart card ───────────────────────────
                            MDBoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: dp(230)
                                md_bg_color: 1, 1, 1, 1
                                radius: [15]
                                padding: dp(15)
