                                    MDBoxLayout:
                                        id: pie_legend
                                        orientation: "vertical"
                                        spacing: dp(8)
                                        padding: [dp(10), 0]
                                        pos_hint: {"center_y": 0.5}

                            # ── Bar chart card ───────────────────────────
                            MDBoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: dp(320)
                                md_bg_color: 1, 1, 1, 1
                                radius: [15]
                                padding: [dp(15), dp(12)]
