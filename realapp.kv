                                MDBoxLayout:
                                    orientation: "horizontal"
                                    size_hint_y: None
                                    height: dp(28)

                                    MDLabel:
                                        text: "Completion of Daily\nTasks"
                                        bold: True
                                        font_size: dp(13)
                                        theme_text_color: "Custom"
                                        text_color: 0.1, 0.1, 0.1, 1

                                    Widget:
                                        size_hint_x: 1

                                    MDIconButton:
                                        icon: "chevron-left"
                                        size_hint: None, None
                                        size: dp(28), dp(28)
                                        theme_icon_color: "Custom"
                                        icon_color: 0.4, 0.4, 0.4, 1
