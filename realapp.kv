                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(72)
                                md_bg_color: app.surface_color
                                radius: [12]
                                padding: [dp(16), 0]
                                spacing: dp(14)

                                MDBoxLayout:
                                    size_hint: None, None
                                    size: dp(38), dp(38)
                                    radius: [19]
                                    md_bg_color: app.primary_color
                                    pos_hint: {"center_y": 0.5}

                                    MDIcon:
                                        icon: "volume-high"
                                        theme_text_color: "Custom"
                                        text_color: 1, 1, 1, 1
                                        halign: "center"
                                        valign: "center"

                                MDBoxLayout:
                                    orientation: "vertical"
                                    pos_hint: {"center_y": 0.5}
