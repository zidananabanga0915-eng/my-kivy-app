                                        theme_text_color: "Custom"
                                        text_color: app.text_secondary
                                        size_hint_y: None
                                        height: dp(18)

                                Widget:
                                    size_hint_x: 1

                                MDSwitch:
                                    active: app.dark_mode
                                    pos_hint: {"center_y": 0.5}
                                    on_active: app.toggle_dark_mode(self.active)

                            MDBoxLayout:
                                orientation: "horizontal"
                                size_hint_y: None
                                height: dp(72)
                                md_bg_color: app.surface_color
                                radius: [12]
                                padding: [dp(16), 0]
                                spacing: dp(14)

                                MDBoxLayout:
                                    size_hint: None, None
                                    size: dp(38), dp(38)
                                    radius: [19]
                                    md_bg_color: app.primary_color
                                    pos_hint: {"center_y": 0.5}

                                    MDIcon:
                                        icon: "gesture-swipe"
