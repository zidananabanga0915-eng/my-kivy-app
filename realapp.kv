                                radius: [26]
                                md_bg_color: 0.16, 0.55, 0.87, 1
                                pos_hint: {"center_y": 0.5}
                                on_touch_down:
                                    if self.collide_point(*args[1].pos): app.set_preview_color([0.16, 0.55, 0.87, 1])

                            MDBoxLayout:
                                size_hint: None, None
