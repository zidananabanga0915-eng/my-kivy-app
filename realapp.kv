<FaqItem@MDBoxLayout>:
    question: ""
    answer: ""
    expanded: False
    orientation: "vertical"
    size_hint_y: None
    height: self.minimum_height
    md_bg_color: 1, 1, 1, 1
    radius: [12]
    padding: [dp(16), dp(14)]
    spacing: dp(8)

    canvas.before:
        Color:
            rgba: 0.88, 0.88, 0.92, 1
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 12)
            width: dp(1)

    # Question row
    MDBoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(36)
        on_touch_down:
            if self.collide_point(*args[1].pos): root.expanded = not root.expanded

        MDLabel:
            text: root.question
            font_size: dp(14)
            bold: True
            theme_text_color: "Custom"
            text_color: 0.18, 0.18, 0.38, 1
            valign: "center"

        MDIcon:
            icon: "chevron-up" if root.expanded else "chevron-down"
            theme_text_color: "Custom"
            text_color: 0.35, 0.35, 0.55, 1
            size_hint: None, None
            size: dp(24), dp(24)
            pos_hint: {"center_y": 0.5}

    # Answer — only visible when expanded
    MDLabel:
        text: root.answer
        font_size: dp(13)
        theme_text_color: "Custom"
        text_color: 0.25, 0.25, 0.45, 1
        size_hint_y: None
        height: self.texture_size[1] + dp(4) if root.expanded else 0
        opacity: 1 if root.expanded else 0


<ContextMenuItem@ButtonBehavior+MDBoxLayout>:
    icon: ""
    label_text: ""
    orientation: "horizontal"
    size_hint_y: None
    height: dp(56)
    padding: [dp(16), 0]
    spacing: dp(20)
    md_bg_color: 1, 1, 1, 1

    on_touch_down:
        if self.collide_point(*args[1].pos): root.dispatch('on_release')

    MDIcon:
        icon: root.icon
        theme_text_color: "Custom"
        text_color: 0.2, 0.2, 0.2, 1
        size_hint: None, None
        size: dp(24), dp(24)
        pos_hint: {"center_y": 0.5}

    MDLabel:
        text: root.label_text
        font_size: dp(15)
        theme_text_color: "Custom"
        text_color: 0.15, 0.15, 0.15, 1
        valign: "center"


<DrawerItem@ButtonBehavior+MDBoxLayout>:
    icon: ""
    label: ""
    orientation: "horizontal"
    size_hint_y: None
    height: dp(52)
    padding: [dp(20), 0]
    spacing: dp(18)

    MDIcon:
        icon: root.icon
        theme_text_color: "Custom"
        text_color: 0.1, 0.1, 0.1, 1
        size_hint: None, None
        size: dp(24), dp(24)
        pos_hint: {"center_y": 0.5}

    MDLabel:
        text: root.label
        font_size: dp(15)
        theme_text_color: "Custom"
        text_color: 0.1, 0.1, 0.1, 1
        valign: "center"


<DayButton@MDBoxLayout>:
    day: 0
    is_today: False
    is_selected: False
    has_task: False
    orientation: "vertical"
    size_hint: 1, None
    height: dp(40)
    spacing: dp(2)

    on_touch_down:
        if self.collide_point(*args[1].pos) and self.day > 0: app.select_day(self.day)

    MDBoxLayout:
        size_hint: None, None
        size: dp(32), dp(32)
        pos_hint: {"center_x": 0.5}
        radius: [16]
        md_bg_color: app.primary_color if root.is_today else (0.85, 0.92, 1, 1) if root.is_selected else (0, 0, 0, 0)

        MDLabel:
            text: str(root.day) if root.day > 0 else ""
            halign: "center"
            valign: "center"
            font_size: dp(13)
            bold: root.is_today
            theme_text_color: "Custom"
            text_color: (1, 1, 1, 1) if root.is_today else (0.1, 0.1, 0.1, 1)

    MDBoxLayout:
        size_hint: None, None
        size: dp(6), dp(6)
        pos_hint: {"center_x": 0.5}
        radius: [3]
        md_bg_color: app.primary_color if root.has_task else (0, 0, 0, 0)


<WeekDayButton@MDBoxLayout>:
    day_num: ""
    day_name: ""
    is_today: False
    date_key: ""
    orientation: "vertical"
    size_hint: 1, None
    height: dp(80)
    spacing: dp(4)
    padding: [4, 8]

    on_touch_down:
        if self.collide_point(*args[1].pos): app.select_day_from_key(self.date_key)

    MDBoxLayout:
        size_hint: None, None
        size: dp(46), dp(60)
        pos_hint: {"center_x": 0.5}
        radius: [12]
        md_bg_color: app.primary_color if root.is_today else (0.2, 0.22, 0.3, 1)
        orientation: "vertical"
        padding: [0, 6]

        MDLabel:
            text: root.day_num
            halign: "center"
            bold: True
            font_size: dp(18)
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        MDLabel:
            text: root.day_name
            halign: "center"
            font_size: dp(11)
            theme_text_color: "Custom"
            text_color: app.primary_color if root.is_today else (0.7, 0.7, 0.7, 1)


<Navitem@BoxLayout>:
    orientation: "vertical"
    padding: 5
    spacing: 2
    icon: ""
    text: ""
    screen: ""

    canvas.before:
        Color:
            rgba: app.primary_color if app.current_screen == root.screen else (0, 0, 0, 0)
        Ellipse:
            size: root.height, root.height
            pos: root.center_x - root.height / 2, root.y

    MDIconButton:
        icon: root.icon
        pos_hint: {"center_x": 0.5}
        theme_icon_color: "Custom"
        ripple_color: 0, 0, 0, 0
        ripple_scale: 0
        icon_color: (1, 1, 1, 1) if app.current_screen == root.screen else (0.5, 0.5, 0.5, 1)
        on_release: app.change_screen(root.screen)

    MDLabel:
        text: root.text
        bold: True
        halign: "center"
        font_style: "Caption"
        theme_text_color: "Custom"
        text_color: (1, 1, 1, 1) if app.current_screen == root.screen else (0.5, 0.5, 0.5, 1)


<PriorityItem>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(48)
    padding: [16, 0]
    spacing: dp(16)

    on_touch_down:
        if self.collide_point(*args[1].pos): root.dispatch('on_release')

    MDIcon:
        icon: root.icon
        theme_text_color: "Custom"
        text_color: root.icon_color
        size_hint: None, None
        size: dp(24), dp(24)
        pos_hint: {"center_y": 0.5}

    MDLabel:
        text: root.text
        theme_text_color: "Custom"
        text_color: 0, 0, 0, 1
        pos_hint: {"center_y": 0.5}


MDScreen:
    md_bg_color: app.bg_color

    MDBoxLayout:
        orientation: "vertical"

        # Header
        MDBoxLayout:
            size_hint: 1, None
            height: dp(56) if app.current_screen not in ("Calendar Screen", "Statistics") else dp(0.01)
            opacity: 1 if app.current_screen not in ("Calendar Screen", "Statistics") else 0
            

            MDIconButton:
                icon: "menu"
                theme_icon_color: "Custom"
                icon_color: 0.3, 0.3, 0.3, 1
                pos_hint: {"center_y": 0.5}
                on_release: app.open_drawer()

            MDLabel:
                text: "To-Do list"
                font_style: "H6"
                bold: True
                theme_text_color: "Custom"
                text_color: 0.1, 0.1, 0.1, 1
                valign: "center"

            Widget:
                size_hint_x: 1

            MDIconButton:
                icon: "magnify"
                theme_icon_color: "Custom"
                icon_color: 0.3, 0.3, 0.3, 1
                pos_hint: {"center_y": 0.5}

            MDIconButton:
                icon: "dots-vertical"
                theme_icon_color: "Custom"
                icon_color: 0.3, 0.3, 0.3, 1
                pos_hint: {"center_y": 0.5}

        # Filter tabs
        MDBoxLayout:
            size_hint: 1, None
            height: dp(48) if app.current_screen not in ("Calendar Screen", "Statistics") else dp(0.01)
            opacity: 1 if app.current_screen not in ("Calendar Screen", "Statistics") else 0
            padding: [15, 0]

            MDLabel:
                id: tab_personal
                text: "Personal"
                bold: app.active_tab == "Personal"
                size_hint_x: 1
                height: dp(48)
                theme_text_color: "Custom"
                text_color: app.primary_color if app.active_tab == "Personal" else [0.5, 0.5, 0.5, 1]
                valign: "center"
                halign: "center"
                on_touch_down: self.collide_point(*args[1].pos) and app.switch_tab("Personal", self)

            MDLabel:
                id: tab_work
                text: "Work"
                bold: app.active_tab == "Work"
                size_hint_x: 1
                height: dp(48)
                theme_text_color: "Custom"
                text_color: app.primary_color if app.active_tab == "Work" else [0.5, 0.5, 0.5, 1]
                valign: "center"
                halign: "center"
                on_touch_down: self.collide_point(*args[1].pos) and app.switch_tab("Work", self)

            MDLabel:
                id: tab_school
                text: "School"
                bold: app.active_tab == "School"
                size_hint_x: 1
                height: dp(48)
                theme_text_color: "Custom"
                text_color: app.primary_color if app.active_tab == "School" else [0.5, 0.5, 0.5, 1]
                valign: "center"
                halign: "center"
                on_touch_down: self.collide_point(*args[1].pos) and app.switch_tab("School", self)

            MDLabel:
                id: tab_other
                text: "Other"
                bold: app.active_tab == "Other"
                size_hint_x: 1
                height: dp(48)
                theme_text_color: "Custom"
                text_color: app.primary_color if app.active_tab == "Other" else [0.5, 0.5, 0.5, 1]
                valign: "center"
                halign: "center"
                on_touch_down: self.collide_point(*args[1].pos) and app.switch_tab("Other", self)

        # Underline
        MDBoxLayout:
            size_hint: 1, None
            height: dp(3) if app.current_screen not in ("Calendar Screen", "Statistics") else dp(0.01)
            opacity: 1 if app.current_screen not in ("Calendar Screen", "Statistics") else 0

            MDBoxLayout:
                id: tab_underline
                size_hint: None, None
                width: dp(80)
                height: dp(3)
                md_bg_color: app.primary_color
                radius: [2]

        # Main ScreenManager
        ScreenManager:
            id: screen_manager
            md_bg_color: app.bg_color

            Screen:
                name: "Task Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    ScreenManager:
                        id: tab_manager

                        Screen:
                            name: "Personal"
                            ScrollView:
                                MDBoxLayout:
                                    id: task_list
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    padding: [15, 10]
                                    spacing: dp(5)

                        Screen:
                            name: "Work"
                            ScrollView:
                                MDBoxLayout:
                                    id: task_list
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    padding: [15, 10]
                                    spacing: dp(5)

                        Screen:
                            name: "School"
                            ScrollView:
                                MDBoxLayout:
                                    id: task_list
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    padding: [15, 10]
                                    spacing: dp(5)

                        Screen:
                            name: "Other"
                            ScrollView:
                                MDBoxLayout:
                                    id: task_list
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    padding: [15, 10]
                                    spacing: dp(5)

            Screen:
                name: "Calendar Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    md_bg_color: app.primary_tint

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(50)
                        padding: [15, 0]

                        MDIconButton:
                            icon: "chevron-left"
                            on_release: app.prev_month()

                        MDLabel:
                            id: month_label
                            text: app.current_month_label
                            halign: "center"
                            bold: True
                            font_size: dp(16)
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1

                        MDIconButton:
                            icon: "chevron-right"
                            on_release: app.next_month()

                        MDIconButton:
                            icon: "view-grid-outline"
                            theme_icon_color: "Custom"
                            icon_color: 0.3, 0.3, 0.3, 1
                            on_release: app.toggle_calendar_view()

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(35) if app.calendar_view == "month" else dp(0.01)
                        opacity: 1 if app.calendar_view == "month" else 0
                        padding: [5, 0]

                        MDLabel:
                            text: "Sun"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                        MDLabel:
                            text: "Mon"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                        MDLabel:
                            text: "Tue"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                        MDLabel:
                            text: "Wed"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                        MDLabel:
                            text: "Thu"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                        MDLabel:
                            text: "Fri"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                        MDLabel:
                            text: "Sat"
                            halign: "center"
                            font_size: dp(12)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1

                    GridLayout:
                        id: calendar_grid
                        cols: 7
                        size_hint_y: None
                        height: dp(280) if app.calendar_view == "month" else dp(90)
                        padding: [5, 0]
                        spacing: dp(2)

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: [15, 10]
                        spacing: dp(5)

                        MDLabel:
                            id: selected_date_label
                            text: "Tap a date to see tasks"
                            halign: "center"
                            font_size: dp(14)
                            bold: True
                            size_hint_y: None
                            height: dp(30)
                            theme_text_color: "Custom"
                            text_color: 0.2, 0.2, 0.2, 1

                        MDLabel:
                            id: no_tasks_label
                            text: "No tasks for the day.\nClick \"+\" to create your tasks."
                            halign: "center"
                            size_hint_y: None
                            height: dp(50)
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1
                            font_size: dp(14)
                            opacity: 1

                        ScrollView:
                            MDBoxLayout:
                                id: calendar_task_list
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_height
                                padding: [0, 5]
                                spacing: dp(5)

                    
    
            Screen:
                name: "Favorites Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    md_bg_color: app.bg_color

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        md_bg_color: app.primary_color
                        padding: [dp(5), 0]
                        spacing: dp(5)

                        MDIconButton:
                            icon: "arrow-left"
                            theme_icon_color: "Custom"
                            icon_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}
                            on_release: app.go_back()

                        MDLabel:
                            text: "Favorites"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            valign: "center"

                    ScrollView:
                        MDBoxLayout:
                            id: favorites_task_list
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            padding: [15, 10]
                            spacing: dp(5)

                    MDLabel:
                        id: favorites_empty_label
                        text: "No favorites yet.\nLong press a task and tap ★ to add."
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 0.5, 0.5, 0.5, 1
                        font_size: dp(14)
                        opacity: 1

            Screen:
                name: "Trash Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    md_bg_color: app.bg_color

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        md_bg_color: app.primary_color
                        padding: [dp(5), 0]
                        spacing: dp(5)

                        MDIconButton:
                            icon: "arrow-left"
                            theme_icon_color: "Custom"
                            icon_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}
                            on_release: app.go_back()

                        MDLabel:
                            text: "Trash"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            valign: "center"

                    ScrollView:
                        MDBoxLayout:
                            id: trash_task_list
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            padding: [15, 10]
                            spacing: dp(5)

                    MDLabel:
                        id: trash_empty_label
                        text: "Trash is empty."
                        halign: "center"
                        theme_text_color: "Custom"
                        text_color: 0.5, 0.5, 0.5, 1
                        font_size: dp(14)
                        opacity: 1

            Screen:
                name: "Theme Screen"
                MDBoxLayout:
                    orientation: "vertical"
                    md_bg_color: app.bg_color

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        md_bg_color: app.primary_color
                        padding: [dp(5), 0]
                        spacing: dp(5)

                        MDIconButton:
                            icon: "arrow-left"
                            theme_icon_color: "Custom"
                            icon_color: 1, 1, 1, 1
                            pos_hint: {"center_y": 0.5}
                            on_release: app.close_theme()

                        MDLabel:
                            text: "Theme"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            valign: "center"

                    MDBoxLayout:
                        orientation: "vertical"
                        md_bg_color: app.bg_color
                        padding: [dp(20), dp(20)]
                        spacing: dp(20)

                        # Phone mockup preview
                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(330)

                            Widget:
                                size_hint_x: 1

                            MDBoxLayout:
                                orientation: "vertical"
                                size_hint: None, None
                                size: dp(195), dp(330)
                                radius: [18]
                                md_bg_color: 1, 1, 1, 1

                                canvas.before:
                                    Color:
                                        rgba: 0.1, 0.1, 0.1, 1
                                    Line:
                                        rounded_rectangle: (self.x, self.y, self.width, self.height, 18)
                                        width: dp(2)

                                MDBoxLayout:
                                    size_hint_y: None
                                    height: dp(36)
                                    md_bg_color: app.theme_preview_color
                                    radius: [18, 18, 0, 0]
                                    padding: [dp(6), 0]
                                    spacing: dp(3)

                                    MDIcon:
                                        icon: "menu"
                                        theme_text_color: "Custom"
                                        text_color: 1, 1, 1, 1
                                        font_size: dp(13)
                                        size_hint: None, None
                                        size: dp(16), dp(36)

                                    MDLabel:
                                        text: "Task List"
                                        font_size: dp(11)
                                        bold: True
                                        theme_text_color: "Custom"
                                        text_color: 1, 1, 1, 1
                                        valign: "center"

                                    Widget:
                                        size_hint_x: 1

                                    MDIcon:
                                        icon: "magnify"
                                        theme_text_color: "Custom"
                                        text_color: 1, 1, 1, 1
                                        font_size: dp(13)
                                        size_hint: None, None
                                        size: dp(16), dp(36)

                                    MDIcon:
                                        icon: "dots-vertical"
                                        theme_text_color: "Custom"
                                        text_color: 1, 1, 1, 1
                                        font_size: dp(13)
                                        size_hint: None, None
                                        size: dp(16), dp(36)

                                MDBoxLayout:
                                    size_hint_y: None
                                    height: dp(22)
                                    padding: [dp(4), 0]
                                    md_bg_color: 0.96, 0.96, 0.96, 1

                                    MDLabel:
                                        text: "Personal"
                                        font_size: dp(7.5)
                                        bold: True
                                        halign: "center"
                                        theme_text_color: "Custom"
                                        text_color: app.theme_preview_color

                                    MDLabel:
                                        text: "Work"
                                        font_size: dp(7.5)
                                        halign: "center"
                                        theme_text_color: "Custom"
                                        text_color: 0.55, 0.55, 0.55, 1

                                    MDLabel:
                                        text: "School"
                                        font_size: dp(7.5)
                                        halign: "center"
                                        theme_text_color: "Custom"
                                        text_color: 0.55, 0.55, 0.55, 1

                                    MDLabel:
                                        text: "Other"
                                        font_size: dp(7.5)
                                        halign: "center"
                                        theme_text_color: "Custom"
                                        text_color: 0.55, 0.55, 0.55, 1

                                MDBoxLayout:
                                    size_hint_y: None
                                    height: dp(2)
                                    padding: [dp(4), 0]

                                    MDBoxLayout:
                                        size_hint: None, None
                                        width: dp(40)
                                        height: dp(2)
                                        md_bg_color: app.theme_preview_color
                                        radius: [1]

                                    Widget:

                                MDBoxLayout:
                                    orientation: "vertical"
                                    padding: [dp(6), dp(5)]
                                    spacing: dp(4)

                                    MDBoxLayout:
                                        size_hint_y: None
                                        height: dp(38)
                                        radius: [6]
                                        md_bg_color: app.theme_preview_tint
                                        padding: [dp(5), 0]
                                        spacing: dp(5)

                                        MDBoxLayout:
                                            size_hint: None, None
                                            size: dp(13), dp(13)
                                            radius: [7]
                                            md_bg_color: 0.75, 0.75, 0.75, 1
                                            pos_hint: {"center_y": 0.5}

                                        MDBoxLayout:
                                            orientation: "vertical"
                                            pos_hint: {"center_y": 0.5}
                                            spacing: dp(2)

                                            MDBoxLayout:
                                                size_hint: 0.65, None
                                                height: dp(6)
                                                md_bg_color: 0.2, 0.2, 0.2, 1
                                                radius: [3]

                                            MDBoxLayout:
                                                size_hint: 0.38, None
                                                height: dp(5)
                                                md_bg_color: 1, 0.3, 0.3, 1
                                                radius: [3]

                                    MDBoxLayout:
                                        size_hint_y: None
                                        height: dp(38)
                                        radius: [6]
                                        md_bg_color: app.theme_preview_tint
                                        padding: [dp(5), 0]
                                        spacing: dp(5)

                                        MDBoxLayout:
                                            size_hint: None, None
                                            size: dp(13), dp(13)
